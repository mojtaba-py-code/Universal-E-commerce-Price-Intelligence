# ---------------------------------------------------------------------------
# Universal E-commerce Price Intelligence - environment configuration
# Copy this file to `.env` and adjust as needed.
# ---------------------------------------------------------------------------

# Database ------------------------------------------------------------------
# Leave DATABASE_URL empty to use the local SQLite file (zero setup).
# To use PostgreSQL (via docker-compose), uncomment the line below.
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://priceintel:priceintel@localhost:5432/priceintel

# Postgres settings used by docker-compose.yml
POSTGRES_USER=priceintel
POSTGRES_PASSWORD=priceintel
POSTGRES_DB=priceintel
POSTGRES_PORT=5432

# Scraper -------------------------------------------------------------------
# fixture -> parse saved HTML (offline, always stable, used by tests)
# live    -> fetch real pages over the network (may be blocked by the store)
SCRAPER_MODE=fixture

# Directory holding saved HTML fixtures for `fixture` mode
FIXTURE_DIR=data/fixtures

# Polite live-scraping delay (seconds) between network requests
REQUEST_DELAY_SECONDS=2.0
REQUEST_TIMEOUT_SECONDS=20.0

# App -----------------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8000
